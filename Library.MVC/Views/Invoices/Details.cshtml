@model Library.Domain.InvoiceLine

@{
    ViewData["Title"] = "Loan Details";
}

<h1>Loan Details</h1>

<dl class="row">
    <dt class="col-sm-2">Member</dt>
    <dd class="col-sm-10">@Model.Invoice?.FullName</dd>

    <dt class="col-sm-2">Book</dt>
    <dd class="col-sm-10">@Model.Product?.Title</dd>

    <dt class="col-sm-2">Loan Date</dt>
    <dd class="col-sm-10">@Model.LoanDate.ToShortDateString()</dd>

    <dt class="col-sm-2">Due Date</dt>
    <dd class="col-sm-10">@Model.DueDate.ToShortDateString()</dd>

    <dt class="col-sm-2">Returned Date</dt>
    <dd class="col-sm-10">
        @(Model.ReturnedDate.HasValue? Model.ReturnedDate.Value.ToShortDateString() : "Not yet returned")
    </dd>

    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">
        @if (Model.ReturnedDate != null)
        {
            <span class="badge bg-success">Returned</span>
        }
        else if (Model.IsOverdue)
        {
            <span class="badge bg-danger">Overdue</span>
        }
        else
        {
            <span class="badge bg-warning text-dark">Active</span>
        }
    </dd>
</dl>

<a asp-action="Index" class="btn btn-secondary">Back to Loans</a>