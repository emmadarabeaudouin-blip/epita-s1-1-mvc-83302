@model IEnumerable<Microsoft.AspNetCore.Identity.IdentityRole>

@{
    ViewData["Title"] = "Role Management";
}

<h1>Role Management</h1>
<hr />

<h4>Create New Role</h4>
<form asp-action="CreateRole" asp-controller="Admin" method="post" class="row g-2 mb-4">
    <div class="col-auto">
        <input type="text" name="roleName" class="form-control" placeholder="Role name" />
    </div>
    <div class="col-auto">
        <button type="submit" class="btn btn-primary">Create Role</button>
    </div>
</form>

<h4>Existing Roles</h4>
<table class="table">
    <thead>
        <tr>
            <th>Role Name</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var role in Model)
        {
            <tr>
                <td>@role.Name</td>
                <td>
                    <form asp-action="DeleteRole" asp-controller="Admin" method="post" class="d-inline">
                        <input type="hidden" name="roleId" value="@role.Id" />
                        <button type="submit" class="btn btn-sm btn-danger"
                                onclick="return confirm('Delete role @role.Name?')">
                            Delete
                        </button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-controller="Home" asp-action="Index" class="btn btn-secondary">Back to Home</a>